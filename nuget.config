<!-- nuget.config (repo root) — hermetic: local restores must resolve EXACTLY what CI does, and
     nothing else. Mirrors the sibling FS-GG repos (see FS.GG.Audio for the full #31 write-up):
     the F# SDK appends its bundled FSharp.Core to RestoreAdditionalProjectSources via MSBuild, which
     `<clear/>` under <packageSources> never sees, so its different-build/different-hash copy can win
     and write a machine-dependent packages.lock.json. packageSourceMapping is the structural fix —
     it constrains the sources NuGet is HANDED, not the ones this file DECLARES — and Directory.Build.props
     also sets DisableImplicitLibraryPacksFolder. Either alone suffices; both together cannot regress. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
